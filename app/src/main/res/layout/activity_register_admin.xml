<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#070714"
    tools:context=".RegisterAdminActivity"
    tools:ignore="HardcodedText,TextFields">

    <ImageView
        android:id="@+id/btnAtrasRegisterAdmin"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="24dp"
        android:src="@android:drawable/ic_menu_revert"
        android:rotation="180"
        app:tint="#E65100"
        android:contentDescription="Regresar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/txtTituloRegisterAdmin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="REGISTRO DE ADMINISTRADOR"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/btnAtrasRegisterAdmin"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/btnAtrasRegisterAdmin" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="32dp"
        android:layout_marginHorizontal="24dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/txtTituloRegisterAdmin"
        app:layout_constraintBottom_toTopOf="@id/btnCrearCuentaAdmin">

        <EditText
            android:id="@+id/txtRegisterAdminNombre"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Nombres"
            android:textColorHint="#555565"
            android:textColor="#FFFFFF"
            android:backgroundTint="#E65100"
            android:layout_marginBottom="16dp"/>

        <EditText
            android:id="@+id/txtRegisterAdminApellidos"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Apellidos"
            android:textColorHint="#555565"
            android:textColor="#FFFFFF"
            android:backgroundTint="#E65100"
            android:layout_marginBottom="16dp"/>

        <EditText
            android:id="@+id/txtRegisterAdminDni"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="DNI"
            android:textColorHint="#555565"
            android:textColor="#FFFFFF"
            android:backgroundTint="#E65100"
            android:inputType="number"
            android:maxLength="8"
            android:layout_marginBottom="16dp"/>

        <EditText
            android:id="@+id/txtRegisterAdminNumero"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Número de Celular"
            android:textColorHint="#555565"
            android:textColor="#FFFFFF"
            android:backgroundTint="#E65100"
            android:inputType="phone"
            android:layout_marginBottom="16dp"/>

        <EditText
            android:id="@+id/txtRegisterAdminCorreo"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Correo Electrónico"
            android:textColorHint="#555565"
            android:textColor="#FFFFFF"
            android:backgroundTint="#E65100"
            android:inputType="textEmailAddress"
            android:layout_marginBottom="16dp"/>

        <EditText
            android:id="@+id/txtRegisterAdminContrasena"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Contraseña"
            android:textColorHint="#555565"
            android:textColor="#FFFFFF"
            android:backgroundTint="#E65100"
            android:inputType="textPassword"/>
    </LinearLayout>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnCrearCuentaAdmin"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="32dp"
        android:background="@drawable/barra_progreso_clip"
        android:backgroundTint="#E65100"
        android:text="CREAR CUENTA"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>