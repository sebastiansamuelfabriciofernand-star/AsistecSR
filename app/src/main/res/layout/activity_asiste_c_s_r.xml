<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context="com.example.asistecsr.AsisteCSR">

    <ImageView
        android:id="@+id/logoDsi"
        android:layout_width="193dp"
        android:layout_height="182dp"
        android:layout_marginTop="24dp"
        android:contentDescription="Logo DSI"
        android:src="@drawable/logo_salazar_romero"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/txtTitulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="ASISTENCIAS-QR"
        android:textColor="@color/black"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/logoDsi"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/txtEstado"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="CARGANDO SU REGISTRO"
        android:textColor="@color/black"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/txtTitulo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/containerBarras"
        android:layout_width="280dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/txtEstado"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <FrameLayout
            android:id="@+id/barra1"
            android:layout_width="match_parent"
            android:layout_height="38dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/fondo_barra_azul"
            android:foreground="@drawable/barra_progreso_clip_azul" />

        <FrameLayout
            android:id="@+id/barra2"
            android:layout_width="match_parent"
            android:layout_height="38dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/fondo_barra_azul"
            android:foreground="@drawable/barra_progreso_clip_azul" />

        <FrameLayout
            android:id="@+id/barra3"
            android:layout_width="match_parent"
            android:layout_height="38dp"
            android:background="@drawable/fondo_barra_azul"
            android:foreground="@drawable/barra_progreso_clip_azul" />
    </LinearLayout>

    <TextView
        android:id="@+id/txtPorcentaje"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="19%"
        android:textColor="@color/rojo_asiste"
        android:textSize="44sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/containerBarras"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/txtBienvenida"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Bienvenido por favor espere"
        android:textColor="@color/black"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/txtPorcentaje"
        app:layout_constraintBottom_toTopOf="@id/containerFooter"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.4" />

    <FrameLayout
        android:id="@+id/containerFooter"
        android:layout_width="75dp"
        android:layout_height="75dp"
        android:layout_marginBottom="24dp"
        android:background="@drawable/fondo_footer_azul"
        android:padding="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/imgFooter"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="Icono Grupo"
            android:src="@drawable/grupo_id" />
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>