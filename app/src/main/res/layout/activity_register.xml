<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0B1A"
    tools:context=".RegisterActivity">

    <ImageView
        android:id="@+id/btnRegresarLogin"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:clickable="true"
        android:focusable="true"
        android:padding="8dp"
        android:contentDescription="Regresar a la pantalla de login"
        android:src="@android:drawable/ic_menu_revert"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="#FF4D4D" />

    <ImageView
        android:id="@+id/imgRegisterLogo"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:layout_marginTop="16dp"
        android:src="@drawable/logo_salazar_romero"
        android:contentDescription="Logo de la institución"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/txtRegisterTitulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="ASISTENCIAS-DSI"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/imgRegisterLogo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/txtSubtitulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="REGÍSTRATE PARA TENER UNA CUENTA"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/txtRegisterTitulo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        android:paddingHorizontal="24dp"
        app:layout_constraintTop_toBottomOf="@id/txtSubtitulo"
        app:layout_constraintBottom_toTopOf="@id/btnCrearCuenta"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <EditText
                android:id="@+id/edtRegUsuario"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/fondo_barra"
                android:backgroundTint="#854340"
                android:hint="INGRESE SU NOMBRE DE USUARIO (MAX 10 CARACTERES)"
                android:textColorHint="#E0E0E0"
                android:textColor="#FFFFFF"
                android:paddingHorizontal="12dp"
                android:textSize="12sp"
                android:inputType="text"
                android:maxLength="10"
                android:importantForAutofill="no" />

            <EditText
                android:id="@+id/edtRegContrasena"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/fondo_barra"
                android:backgroundTint="#854340"
                android:hint="INGRESE SU CONTRASEÑA (MAX 6 CARACTERES)"
                android:textColorHint="#E0E0E0"
                android:textColor="#FFFFFF"
                android:paddingHorizontal="12dp"
                android:textSize="12sp"
                android:inputType="textPassword"
                android:maxLength="8"
                android:importantForAutofill="no" />

            <EditText
                android:id="@+id/edtRegNombre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/fondo_barra"
                android:backgroundTint="#854340"
                android:hint="INGRESE NOMBRES Y APELLIDOS COMPLETOS"
                android:textColorHint="#E0E0E0"
                android:textColor="#FFFFFF"
                android:paddingHorizontal="12dp"
                android:textSize="12sp"
                android:inputType="textCapWords"
                android:importantForAutofill="no" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <EditText
                    android:id="@+id/edtRegEdad"
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:minHeight="48dp"
                    android:background="@drawable/fondo_barra"
                    android:backgroundTint="#854340"
                    android:hint="EDAD"
                    android:textColorHint="#E0E0E0"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:textSize="12sp"
                    android:inputType="number"
                    android:maxLength="3"
                    android:importantForAutofill="no" />

                <EditText
                    android:id="@+id/edtRegTelefono"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:minHeight="48dp"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/fondo_barra"
                    android:backgroundTint="#854340"
                    android:hint="NUMERO TELEFONICO"
                    android:textColorHint="#E0E0E0"
                    android:textColor="#FFFFFF"
                    android:paddingHorizontal="12dp"
                    android:textSize="12sp"
                    android:inputType="phone"
                    android:importantForAutofill="no" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <EditText
                    android:id="@+id/edtRegEspecialidad"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:minHeight="48dp"
                    android:layout_weight="2"
                    android:background="@drawable/fondo_barra"
                    android:backgroundTint="#854340"
                    android:hint="ESPECIALIDAD"
                    android:textColorHint="#E0E0E0"
                    android:textColor="#FFFFFF"
                    android:paddingHorizontal="12dp"
                    android:textSize="12sp"
                    android:inputType="text"
                    android:importantForAutofill="no" />

                <EditText
                    android:id="@+id/edtRegCiclo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:minHeight="48dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/fondo_barra"
                    android:backgroundTint="#854340"
                    android:hint="CICLO"
                    android:textColorHint="#E0E0E0"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:textSize="12sp"
                    android:inputType="text"
                    android:importantForAutofill="no" />

                <EditText
                    android:id="@+id/edtRegTurno"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:minHeight="48dp"
                    android:layout_weight="1.2"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/fondo_barra"
                    android:backgroundTint="#854340"
                    android:hint="TURNO"
                    android:textColorHint="#E0E0E0"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:textSize="12sp"
                    android:inputType="text"
                    android:importantForAutofill="no" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <EditText
                    android:id="@+id/edtRegDni"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:minHeight="48dp"
                    android:layout_weight="1"
                    android:background="@drawable/fondo_barra"
                    android:backgroundTint="#854340"
                    android:hint="DNI"
                    android:textColorHint="#E0E0E0"
                    android:textColor="#FFFFFF"
                    android:paddingHorizontal="12dp"
                    android:textSize="12sp"
                    android:inputType="number"
                    android:maxLength="8"
                    android:importantForAutofill="no" />

                <EditText
                    android:id="@+id/edtRegEmail"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:minHeight="48dp"
                    android:layout_weight="1.3"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/fondo_barra"
                    android:backgroundTint="#854340"
                    android:hint="E-MAIL"
                    android:textColorHint="#E0E0E0"
                    android:textColor="#FFFFFF"
                    android:paddingHorizontal="12dp"
                    android:textSize="12sp"
                    android:inputType="textEmailAddress"
                    android:importantForAutofill="no" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnCrearCuenta"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginHorizontal="40dp"
        android:layout_marginBottom="24dp"
        android:text="CREAR CUENTA"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:textSize="16sp"
        android:background="@drawable/fondo_btn_administrador"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>