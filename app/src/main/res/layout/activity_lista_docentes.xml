<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#070714"
    tools:ignore="HardcodedText,ContentDescription">

    <LinearLayout
        android:id="@+id/layoutHeaderLista"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnAtrasLista"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:padding="8dp"
            android:src="@android:drawable/ic_menu_revert"
            android:rotation="180"
            app:tint="#FF3D00"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="LISTA DE DOCENTES"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginEnd="48dp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutFiltrosLista"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:background="@drawable/fondo_barra"
        android:backgroundTint="#202238"
        android:orientation="vertical"
        android:padding="12dp"
        app:layout_constraintTop_toBottomOf="@id/layoutHeaderLista">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FILTROS:"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2">

            <EditText
                android:id="@+id/etBuscarDocente"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1.3"
                android:background="@drawable/fondo_barra"
                android:backgroundTint="#2C304E"
                android:hint="BUSCAR DOCENTE"
                android:textColorHint="#AAAAAA"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:paddingStart="12dp"
                android:gravity="center_vertical"
                android:inputType="text"
                android:importantForAutofill="no"/>

            <View android:layout_width="8dp" android:layout_height="match_parent"/>

            <Spinner
                android:id="@+id/spinnerTurnoLista"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="0.7"
                android:background="@drawable/fondo_barra"
                android:backgroundTint="#B388FF"/>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutEstadisticas"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/fondo_barra"
        android:backgroundTint="#1D203E"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp">

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/grupo_id" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TOTAL DE DOCENTES"
                android:textColor="#AAAAAA"
                android:textSize="9sp" />
            <TextView
                android:id="@+id/txtTotalDocentesCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <View android:layout_width="1dp" android:layout_height="30dp" android:background="#444664"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ACTIVOS"
                android:textColor="#AAAAAA"
                android:textSize="9sp" />
            <TextView
                android:id="@+id/txtActivosCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <View android:layout_width="1dp" android:layout_height="30dp" android:background="#444664"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="INACTIVOS"
                android:textColor="#AAAAAA"
                android:textSize="9sp" />
            <TextView
                android:id="@+id/txtInactivosCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnAsistenciasTop"
        android:layout_width="220dp"
        android:layout_height="48dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="16dp"
        android:text="LISTA DE ASISTENCIAS DE LOS ALUMNOS"
        android:textColor="#FFFFFF"
        android:textSize="9sp"
        android:textStyle="bold"
        android:background="@drawable/barra_progreso_clip"
        android:backgroundTint="#3F51B5"
        android:paddingHorizontal="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutEstadisticas" />

    <TextView
        android:id="@+id/txtTituloCarreraDinamico"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="16dp"
        android:text="DOCENTES"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:textStyle="bold"
        android:gravity="center_horizontal"
        app:layout_constraintTop_toBottomOf="@id/btnAsistenciasTop" />

    <LinearLayout
        android:id="@+id/layoutTableHeaders"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="16dp"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp"
        app:layout_constraintTop_toBottomOf="@id/txtTituloCarreraDinamico">

        <TextView
            android:layout_width="28dp"
            android:layout_height="wrap_content"
            android:text="#"
            android:textColor="#5C6BC0"
            android:textSize="12sp"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.3"
            android:layout_marginStart="46dp"
            android:text="DOCENTE"
            android:textColor="#5C6BC0"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.9"
            android:text="Clase"
            android:textColor="#5C6BC0"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.3"
            android:text="Correo"
            android:textColor="#5C6BC0"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvDocentes"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/layoutTableHeaders"
        app:layout_constraintBottom_toTopOf="@id/layoutPaginacion" />

    <LinearLayout
        android:id="@+id/layoutPaginacion"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/txtMostrandoAlumnos"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="MOSTRANDO REGISTROS"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btnPag1"
                android:layout_width="36dp"
                android:layout_height="48dp"
                android:background="#2C304E"
                android:text="1"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:textStyle="bold"
                android:layout_marginEnd="4dp"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/btnPag2"
                android:layout_width="36dp"
                android:layout_height="48dp"
                android:background="#2C304E"
                android:text="2"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:layout_marginEnd="4dp"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/btnPagSiguiente"
                android:layout_width="36dp"
                android:layout_height="48dp"
                android:background="#2C304E"
                android:text="&gt;"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>