<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo_oscuro"
    android:fillViewport="true"
    tools:context=".SeleccionAsistenciaActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/btnAtrasSeleccion"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginTop="16dp"
            android:src="@android:drawable/ic_menu_revert"
            android:rotation="180"
            app:tint="#E65100"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/txtTituloSeleccion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LISTA DE ASISTENCIA"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginStart="16dp"
            app:layout_constraintBottom_toBottomOf="@id/btnAtrasSeleccion"
            app:layout_constraintStart_toEndOf="@id/btnAtrasSeleccion"
            app:layout_constraintTop_toTopOf="@id/btnAtrasSeleccion" />

        <androidx.cardview.widget.CardView
            android:id="@+id/cardFiltros"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="#1A1736"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:layout_constraintTop_toBottomOf="@id/txtTituloSeleccion">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FILTROS:"
                    android:textColor="#8A8A9E"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <Spinner
                        android:id="@+id/spinnerTurnoAsistencia"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:background="#25214A"/>

                    <Spinner
                        android:id="@+id/spinnerCicloAsistencia"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:background="#25214A"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <Button
            android:id="@+id/btnIrListaAlumnos"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginTop="12dp"
            android:backgroundTint="#3F51B5"
            android:text="LISTA DE ALUMNOS"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:textStyle="bold"
            android:paddingHorizontal="12dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cardFiltros" />

        <GridLayout
            android:id="@+id/gridContenedorCiclos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:columnCount="2"
            android:alignmentMode="alignMargins"
            android:columnOrderPreserved="false"
            app:layout_constraintTop_toBottomOf="@id/btnIrListaAlumnos">

            <androidx.cardview.widget.CardView android:id="@+id/btn1Diurno" style="@style/TarjetaAsistenciaStyle">
                <LinearLayout style="@style/ContenedorTarjetaStyle">
                    <TextView style="@style/TextoTarjetaStyle" android:text="PRIMER CICLO\nTURNO DIURNO" />
                    <androidx.appcompat.widget.AppCompatImageView style="@style/IconoTarjetaStyle" android:src="@drawable/ic_usuarios" app:tint="#131026" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView android:id="@+id/btn1Nocturno" style="@style/TarjetaAsistenciaStyle">
                <LinearLayout style="@style/ContenedorTarjetaStyle">
                    <TextView style="@style/TextoTarjetaStyle" android:text="PRIMER CICLO\nTURNO NOCTURNO" />
                    <androidx.appcompat.widget.AppCompatImageView style="@style/IconoTarjetaStyle" android:src="@drawable/ic_usuarios" app:tint="#131026" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView android:id="@+id/btn2Diurno" style="@style/TarjetaAsistenciaStyle">
                <LinearLayout style="@style/ContenedorTarjetaStyle">
                    <TextView style="@style/TextoTarjetaStyle" android:text="SEGUNDO CICLO\nTURNO DIURNO" />
                    <androidx.appcompat.widget.AppCompatImageView style="@style/IconoTarjetaStyle" android:src="@drawable/ic_usuarios" app:tint="#131026" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView android:id="@+id/btn2Nocturno" style="@style/TarjetaAsistenciaStyle">
                <LinearLayout style="@style/ContenedorTarjetaStyle">
                    <TextView style="@style/TextoTarjetaStyle" android:text="SEGUNDO CICLO\nTURNO NOCTURNO" />
                    <androidx.appcompat.widget.AppCompatImageView style="@style/IconoTarjetaStyle" android:src="@drawable/ic_usuarios" app:tint="#131026" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView android:id="@+id/btn3Diurno" style="@style/TarjetaAsistenciaStyle">
                <LinearLayout style="@style/ContenedorTarjetaStyle">
                    <TextView style="@style/TextoTarjetaStyle" android:text="TERCER CICLO\nTURNO DIURNO" />
                    <androidx.appcompat.widget.AppCompatImageView style="@style/IconoTarjetaStyle" android:src="@drawable/ic_usuarios" app:tint="#131026" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView android:id="@+id/btn3Nocturno" style="@style/TarjetaAsistenciaStyle">
                <LinearLayout style="@style/ContenedorTarjetaStyle">
                    <TextView style="@style/TextoTarjetaStyle" android:text="TERCER CICLO\nTURNO NOCTURNO" />
                    <androidx.appcompat.widget.AppCompatImageView style="@style/IconoTarjetaStyle" android:src="@drawable/ic_usuarios" app:tint="#131026" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView android:id="@+id/btn4Diurno" style="@style/TarjetaAsistenciaStyle">
                <LinearLayout style="@style/ContenedorTarjetaStyle">
                    <TextView style="@style/TextoTarjetaStyle" android:text="CUARTO CICLO\nTURNO DIURNO" />
                    <androidx.appcompat.widget.AppCompatImageView style="@style/IconoTarjetaStyle" android:src="@drawable/ic_usuarios" app:tint="#131026" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView android:id="@+id/btn4Nocturno" style="@style/TarjetaAsistenciaStyle">
                <LinearLayout style="@style/ContenedorTarjetaStyle">
                    <TextView style="@style/TextoTarjetaStyle" android:text="CUARTO CICLO\nTURNO NOCTURNO" />
                    <androidx.appcompat.widget.AppCompatImageView style="@style/IconoTarjetaStyle" android:src="@drawable/ic_usuarios" app:tint="#131026" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView android:id="@+id/btn5Diurno" style="@style/TarjetaAsistenciaStyle">
                <LinearLayout style="@style/ContenedorTarjetaStyle">
                    <TextView style="@style/TextoTarjetaStyle" android:text="QUINTO CICLO\nTURNO DIURNO" />
                    <androidx.appcompat.widget.AppCompatImageView style="@style/IconoTarjetaStyle" android:src="@drawable/ic_usuarios" app:tint="#131026" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView android:id="@+id/btn5Nocturno" style="@style/TarjetaAsistenciaStyle">
                <LinearLayout style="@style/ContenedorTarjetaStyle">
                    <TextView style="@style/TextoTarjetaStyle" android:text="QUINTO CICLO\nTURNO NOCTURNO" />
                    <androidx.appcompat.widget.AppCompatImageView style="@style/IconoTarjetaStyle" android:src="@drawable/ic_usuarios" app:tint="#131026" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView android:id="@+id/btn6Diurno" style="@style/TarjetaAsistenciaStyle">
                <LinearLayout style="@style/ContenedorTarjetaStyle">
                    <TextView style="@style/TextoTarjetaStyle" android:text="SEXTO CICLO\nTURNO DIURNO" />
                    <androidx.appcompat.widget.AppCompatImageView style="@style/IconoTarjetaStyle" android:src="@drawable/ic_usuarios" app:tint="#131026" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView android:id="@+id/btn6Nocturno" style="@style/TarjetaAsistenciaStyle">
                <LinearLayout style="@style/ContenedorTarjetaStyle">
                    <TextView style="@style/TextoTarjetaStyle" android:text="SEXTO CICLO\nTURNO NOCTURNO" />
                    <androidx.appcompat.widget.AppCompatImageView style="@style/IconoTarjetaStyle" android:src="@drawable/ic_usuarios" app:tint="#131026" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </GridLayout>

        <Button
            android:id="@+id/btnActualizarCarpeta"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="16dp"
            android:backgroundTint="@color/rojo_brillante"
            android:text="ACTUALIZAR CARPETA"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:paddingHorizontal="24dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/gridContenedorCiclos" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>