<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#070714"
    tools:ignore="HardcodedText,ContentDescription">

    <LinearLayout
        android:id="@+id/layoutHeaderSelector"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnAtrasSelector"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:padding="8dp"
            android:src="@android:drawable/ic_menu_revert"
            android:rotation="180"
            app:tint="#FF3D00"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Botón Atrás" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="LISTA  DE DOCENTES"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginEnd="48dp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutFiltrosSelector"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="4dp"
        android:background="@drawable/fondo_barra"
        android:backgroundTint="#202238"
        android:orientation="vertical"
        android:padding="12dp"
        app:layout_constraintTop_toBottomOf="@id/layoutHeaderSelector">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FILTROS:"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3">

            <EditText
                android:id="@+id/etBuscarArea"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1.2"
                android:background="@drawable/fondo_barra"
                android:backgroundTint="#2C304E"
                android:hint="BUSCAR AREA"
                android:textColorHint="#AAAAAA"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:paddingStart="12dp"
                android:gravity="center_vertical"
                android:inputType="text"
                android:importantForAutofill="no"/>

            <View android:layout_width="6dp" android:layout_height="match_parent"/>

            <Spinner
                android:id="@+id/spinnerTurno"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1.0"
                android:background="@drawable/fondo_barra"
                android:backgroundTint="#5C6BC0"/>

            <View android:layout_width="6dp" android:layout_height="match_parent"/>

            <Spinner
                android:id="@+id/spinnerCiclo"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="0.8"
                android:background="@drawable/fondo_barra"
                android:backgroundTint="#B388FF"/>
        </LinearLayout>
    </LinearLayout>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnListaDocenteTop"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:minHeight="48dp"
        android:minWidth="48dp"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="16dp"
        android:text="LISTA DE DOCENTE"
        android:textColor="#FFFFFF"
        android:textSize="10sp"
        android:textStyle="bold"
        android:background="@drawable/barra_progreso_clip"
        android:backgroundTint="#3F51B5"
        android:paddingHorizontal="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutFiltrosSelector" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/btnListaDocenteTop"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="90dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="16dp">

                <LinearLayout android:id="@+id/cardMedicina" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginEnd="8dp" android:background="@drawable/fondo_barra" android:backgroundTint="#282962" android:orientation="vertical" android:gravity="center" android:padding="12dp" android:clickable="true" android:focusable="true">
                    <TextView android:layout_width="wrap_content" android:layout_height="0dp" android:layout_weight="1" android:text="MEDICINA TECNICA" android:textColor="#FFFFFF" android:textSize="13sp" android:textStyle="bold" android:gravity="center" />
                    <ImageView android:layout_width="35dp" android:layout_height="35dp" android:src="@drawable/grupo_id" />
                </LinearLayout>

                <LinearLayout android:id="@+id/cardMecatronica" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginStart="8dp" android:background="@drawable/fondo_barra" android:backgroundTint="#282962" android:orientation="vertical" android:gravity="center" android:padding="12dp" android:clickable="true" android:focusable="true">
                    <TextView android:layout_width="wrap_content" android:layout_height="0dp" android:layout_weight="1" android:text="MECATRONICA\nAUTOMOTRIZ" android:textColor="#FFFFFF" android:textSize="13sp" android:textStyle="bold" android:gravity="center" />
                    <ImageView android:layout_width="35dp" android:layout_height="35dp" android:src="@drawable/grupo_id" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="16dp">

                <LinearLayout android:id="@+id/cardSistemas" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginEnd="8dp" android:background="@drawable/fondo_barra" android:backgroundTint="#282962" android:orientation="vertical" android:gravity="center" android:padding="12dp" android:clickable="true" android:focusable="true">
                    <TextView android:layout_width="wrap_content" android:layout_height="0dp" android:layout_weight="1" android:text="DESARROLLO DE SISTEMAS E INFORMACION" android:textColor="#FFFFFF" android:textSize="12sp" android:textStyle="bold" android:gravity="center" />
                    <ImageView android:layout_width="35dp" android:layout_height="35dp" android:src="@drawable/grupo_id" />
                </LinearLayout>

                <LinearLayout android:id="@+id/cardContabilidad" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginStart="8dp" android:background="@drawable/fondo_barra" android:backgroundTint="#282962" android:orientation="vertical" android:gravity="center" android:padding="12dp" android:clickable="true" android:focusable="true">
                    <TextView android:layout_width="wrap_content" android:layout_height="0dp" android:layout_weight="1" android:text="CONTABILIDAD" android:textColor="#FFFFFF" android:textSize="13sp" android:textStyle="bold" android:gravity="center" />
                    <ImageView android:layout_width="35dp" android:layout_height="35dp" android:src="@drawable/grupo_id" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="16dp">

                <LinearLayout android:id="@+id/cardElectricidad" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginEnd="8dp" android:background="@drawable/fondo_barra" android:backgroundTint="#282962" android:orientation="vertical" android:gravity="center" android:padding="12dp" android:clickable="true" android:focusable="true">
                    <TextView android:layout_width="wrap_content" android:layout_height="0dp" android:layout_weight="1" android:text="ELECTRICIDAD\nINDUSTRIAL" android:textColor="#FFFFFF" android:textSize="13sp" android:textStyle="bold" android:gravity="center" />
                    <ImageView android:layout_width="35dp" android:layout_height="35dp" android:src="@drawable/grupo_id" />
                </LinearLayout>

                <LinearLayout android:id="@+id/cardQuimica" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginStart="8dp" android:background="@drawable/fondo_barra" android:backgroundTint="#282962" android:orientation="vertical" android:gravity="center" android:padding="12dp" android:clickable="true" android:focusable="true">
                    <TextView android:layout_width="wrap_content" android:layout_height="0dp" android:layout_weight="1" android:text="QUIMICA" android:textColor="#FFFFFF" android:textSize="13sp" android:textStyle="bold" android:gravity="center" />
                    <ImageView android:layout_width="35dp" android:layout_height="35dp" android:src="@drawable/grupo_id" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:orientation="horizontal"
                android:weightSum="2">

                <LinearLayout android:id="@+id/cardCursos" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginEnd="8dp" android:background="@drawable/fondo_barra" android:backgroundTint="#282962" android:orientation="vertical" android:gravity="center" android:padding="12dp" android:clickable="true" android:focusable="true">
                    <TextView android:layout_width="wrap_content" android:layout_height="0dp" android:layout_weight="1" android:text="CURSOS IMPLEMENTARIOS" android:textColor="#FFFFFF" android:textSize="12sp" android:textStyle="bold" android:gravity="center" />
                    <ImageView android:layout_width="35dp" android:layout_height="35dp" android:src="@drawable/grupo_id" />
                </LinearLayout>

                <View
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnActualizarCarpeta"
        android:layout_width="165dp"
        android:layout_height="48dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="24dp"
        android:text="ACTUALIZAR CARPETA"
        android:textColor="#FFFFFF"
        android:textSize="11sp"
        android:textStyle="bold"
        android:background="@drawable/barra_progreso_clip"
        android:backgroundTint="#D84315"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>