<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#070714"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal">

    <!-- Encabezado de la pantalla -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="30dp">

        <ImageView
            android:id="@+id/btnAtrasRegisterEstudiante"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentStart="true"
            android:layout_centerInParent="true"
            android:src="@android:drawable/ic_menu_revert"
            android:contentDescription="Volver" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="REGISTRO DE ESTUDIANTE"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <!-- Contenedor con Scroll para albergar todos los campos de la BD -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <!-- Campo: Nombres -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nombres"
                android:textColor="#8A8A9E"
                android:textSize="14sp"
                android:layout_marginBottom="6dp"/>
            <EditText
                android:id="@+id/txtRegisterNombre"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="#1C1C2E"
                android:hint="Ej. Carlos Augusto"
                android:textColorHint="#4E4E61"
                android:textColor="#FFFFFF"
                android:paddingHorizontal="16dp"
                android:inputType="textPersonName"
                android:layout_marginBottom="16dp"/>

            <!-- Campo: Apellidos -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Apellidos"
                android:textColor="#8A8A9E"
                android:textSize="14sp"
                android:layout_marginBottom="6dp"/>
            <EditText
                android:id="@+id/txtRegisterApellidos"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="#1C1C2E"
                android:hint="Ej. Ramos Flores"
                android:textColorHint="#4E4E61"
                android:textColor="#FFFFFF"
                android:paddingHorizontal="16dp"
                android:inputType="textPersonName"
                android:layout_marginBottom="16dp"/>

            <!-- Campo: DNI -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Documento Nacional de Identidad (DNI)"
                android:textColor="#8A8A9E"
                android:textSize="14sp"
                android:layout_marginBottom="6dp"/>
            <EditText
                android:id="@+id/txtRegisterDni"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="#1C1C2E"
                android:hint="Ej. 74859612"
                android:textColorHint="#4E4E61"
                android:textColor="#FFFFFF"
                android:paddingHorizontal="16dp"
                android:inputType="number"
                android:maxLength="8"
                android:layout_marginBottom="16dp"/>

            <!-- Campo: Edad -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Edad"
                android:textColor="#8A8A9E"
                android:textSize="14sp"
                android:layout_marginBottom="6dp"/>
            <EditText
                android:id="@+id/txtRegisterEdad"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="#1C1C2E"
                android:hint="Ej. 19"
                android:textColorHint="#4E4E61"
                android:textColor="#FFFFFF"
                android:paddingHorizontal="16dp"
                android:inputType="number"
                android:maxLength="2"
                android:layout_marginBottom="16dp"/>

            <!-- Campo: Ciclo -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ciclo Académico"
                android:textColor="#8A8A9E"
                android:textSize="14sp"
                android:layout_marginBottom="6dp"/>
            <EditText
                android:id="@+id/txtRegisterCiclo"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="#1C1C2E"
                android:hint="Número del 1 al 10"
                android:textColorHint="#4E4E61"
                android:textColor="#FFFFFF"
                android:paddingHorizontal="16dp"
                android:inputType="number"
                android:maxLength="2"
                android:layout_marginBottom="16dp"/>

            <!-- Campo: Carrera -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Carrera Profesional"
                android:textColor="#8A8A9E"
                android:textSize="14sp"
                android:layout_marginBottom="6dp"/>
            <EditText
                android:id="@+id/txtRegisterCarrera"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="#1C1C2E"
                android:hint="Ej. Ingeniería de Sistemas"
                android:textColorHint="#4E4E61"
                android:textColor="#FFFFFF"
                android:paddingHorizontal="16dp"
                android:inputType="text"
                android:layout_marginBottom="16dp"/>

            <!-- Campo: Turno -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Turno"
                android:textColor="#8A8A9E"
                android:textSize="14sp"
                android:layout_marginBottom="6dp"/>
            <EditText
                android:id="@+id/txtRegisterTurno"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="#1C1C2E"
                android:hint="Mañana / Tarde / Noche"
                android:textColorHint="#4E4E61"
                android:textColor="#FFFFFF"
                android:paddingHorizontal="16dp"
                android:inputType="text"
                android:layout_marginBottom="16dp"/>

            <!-- Campo: Correo -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Correo Electrónico"
                android:textColor="#8A8A9E"
                android:textSize="14sp"
                android:layout_marginBottom="6dp"/>
            <EditText
                android:id="@+id/txtRegisterCorreo"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="#1C1C2E"
                android:hint="ejemplo@estudiante.edu.pe"
                android:textColorHint="#4E4E61"
                android:textColor="#FFFFFF"
                android:paddingHorizontal="16dp"
                android:inputType="textEmailAddress"
                android:layout_marginBottom="16dp"/>

            <!-- Campo: Contraseña -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Contraseña de la Cuenta"
                android:textColor="#8A8A9E"
                android:textSize="14sp"
                android:layout_marginBottom="6dp"/>
            <EditText
                android:id="@+id/txtRegisterContrasena"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="#1C1C2E"
                android:hint="Mínimo 6 caracteres"
                android:textColorHint="#4E4E61"
                android:textColor="#FFFFFF"
                android:paddingHorizontal="16dp"
                android:inputType="textPassword"
                android:layout_marginBottom="30dp"/>

            <!-- Botón de Registro -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnCrearCuentaEstudiante"
                android:layout_width="240dp"
                android:layout_height="50dp"
                android:background="@drawable/fondo_btn_volver"
                android:text="REGISTRAR ESTUDIANTE"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:layout_marginBottom="24dp"/>
        </LinearLayout>
    </ScrollView>
</LinearLayout>