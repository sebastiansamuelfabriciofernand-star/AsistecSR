<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#070714"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal">

    <!-- Encabezado de la pantalla -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="30dp">

        <ImageView
            android:id="@+id/btnAtrasRegisterEstudiante"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentStart="true"
            android:layout_centerInParent="true"
            android:src="@android:drawable/ic_menu_revert"
            android:contentDescription="@string/desc_volver" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="@string/titulo_registro_estudiante"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <!-- Contenedor con Scroll para albergar todos los campos de la BD -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <!-- Campo: Nombres -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/label_nombres"
                android:textColor="#8A8A9E"
                android:textSize="14sp"
                android:layout_marginBottom="6dp"/>
            <EditText
                android:id="@+id/txtRegisterNombre"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/fondo_edittext_moderno"
                android:hint="@string/hint_nombres"
                android:textColorHint="#4E4E61"
                android:textColor="#FFFFFF"
                android:paddingHorizontal="16dp"
                android:inputType="textPersonName"
                android:autofillHints="name"
                android:layout_marginBottom="16dp"/>

            <!-- Campo: Apellidos -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/label_apellidos"
                android:textColor="#8A8A9E"
                android:textSize="14sp"
                android:layout_marginBottom="6dp"/>
            <EditText
                android:id="@+id/txtRegisterApellidos"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/fondo_edittext_moderno"
                android:hint="@string/hint_apellidos"
                android:textColorHint="#4E4E61"
                android:textColor="#FFFFFF"
                android:paddingHorizontal="16dp"
                android:inputType="textPersonName"
                android:autofillHints="personFamilyName"
                android:layout_marginBottom="16dp"/>

            <!-- Campo: DNI -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/label_dni"
                android:textColor="#8A8A9E"
                android:textSize="14sp"
                android:layout_marginBottom="6dp"/>
            <EditText
                android:id="@+id/txtRegisterDni"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/fondo_edittext_moderno"
                android:hint="@string/hint_dni"
                android:textColorHint="#4E4E61"
                android:textColor="#FFFFFF"
                android:paddingHorizontal="16dp"
                android:inputType="number"
                android:maxLength="8"
                android:autofillHints="none"
                android:layout_marginBottom="16dp"/>

            <!-- Campo: Edad -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/label_edad"
                android:textColor="#8A8A9E"
                android:textSize="14sp"
                android:layout_marginBottom="6dp"/>
            <EditText
                android:id="@+id/txtRegisterEdad"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/fondo_edittext_moderno"
                android:hint="@string/hint_edad"
                android:textColorHint="#4E4E61"
                android:textColor="#FFFFFF"
                android:paddingHorizontal="16dp"
                android:inputType="number"
                android:maxLength="2"
                android:autofillHints="none"
                android:layout_marginBottom="16dp"/>

            <!-- Campo: Ciclo -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/label_ciclo_academico"
                android:textColor="#8A8A9E"
                android:textSize="14sp"
                android:layout_marginBottom="6dp"/>
            <Spinner
                android:id="@+id/spinnerRegisterCiclo"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/fondo_spinner_moderno"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="16dp"
                android:spinnerMode="dropdown"/>

            <!-- Campo: Carrera -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/label_carrera_profesional"
                android:textColor="#8A8A9E"
                android:textSize="14sp"
                android:layout_marginBottom="6dp"/>
            <Spinner
                android:id="@+id/spinnerRegisterCarrera"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/fondo_spinner_moderno"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="16dp"
                android:spinnerMode="dropdown"/>

            <!-- Campo: Turno -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/label_turno"
                android:textColor="#8A8A9E"
                android:textSize="14sp"
                android:layout_marginBottom="6dp"/>
            <Spinner
                android:id="@+id/spinnerRegisterTurno"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/fondo_spinner_moderno"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="16dp"
                android:spinnerMode="dropdown"/>

            <!-- Campo: Correo -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/label_correo_electronico"
                android:textColor="#8A8A9E"
                android:textSize="14sp"
                android:layout_marginBottom="6dp"/>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">
                <EditText
                    android:id="@+id/txtRegisterCorreoPrefijo"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/fondo_edittext_moderno"
                    android:hint="@string/hint_correo_prefijo"
                    android:textColorHint="#4E4E61"
                    android:textColor="#FFFFFF"
                    android:paddingHorizontal="12dp"
                    android:inputType="text"
                    android:singleLine="true"
                    android:autofillHints="emailAddress"/>
                <View
                    android:layout_width="8dp"
                    android:layout_height="match_parent"/>
                <Spinner
                    android:id="@+id/spinnerRegisterCorreoDominio"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:minWidth="130dp"
                    android:background="@drawable/fondo_spinner_moderno"
                    android:paddingHorizontal="8dp"
                    android:spinnerMode="dropdown"/>
            </LinearLayout>

            <!-- Campo: Contraseña -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/label_contrasena_cuenta"
                android:textColor="#8A8A9E"
                android:textSize="14sp"
                android:layout_marginBottom="6dp"/>
            <EditText
                android:id="@+id/txtRegisterContrasena"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/fondo_edittext_moderno"
                android:hint="@string/hint_min_caracteres"
                android:textColorHint="#4E4E61"
                android:textColor="#FFFFFF"
                android:paddingHorizontal="16dp"
                android:inputType="textPassword"
                android:autofillHints="password"
                android:layout_marginBottom="30dp"/>

            <!-- Botón de Registro -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnCrearCuentaEstudiante"
                android:layout_width="240dp"
                android:layout_height="50dp"
                android:background="@drawable/fondo_btn_volver"
                android:text="@string/btn_registrar_estudiante"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:layout_marginBottom="24dp"/>
        </LinearLayout>
    </ScrollView>
</LinearLayout>